# Use DATABASE_URL (takes precedence) or individual vars
DATABASE_URL=postgres://postgres:password@localhost:5432/high5

# Individual connection vars (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=high5
DB_USER=postgres
DB_PASSWORD=password

PORT=8000

# Lista de jogos autorizados a submeter highscores.
# Cada apiKey deve ser uma string aleatória longa (ex: gerada com openssl rand -hex 32).
HIGHSCORE_GAMES=[{"game":"tetris","apiKey":"hs_abc123..."},{"game":"snake","apiKey":"hs_xyz789..."}]
